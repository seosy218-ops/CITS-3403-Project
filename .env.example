# Copy this file to .env and fill in real values before deploying.
# Never commit .env to version control.

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# SQLAlchemy connection string (defaults to SQLite for local dev)
DATABASE_URL=sqlite:///tunefeed.db

# Set to "true" to enable the Werkzeug debugger (dev only — never enable in production)
FLASK_DEBUG=false

# Port the development server binds to
PORT=5002
